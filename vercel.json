{
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://web-production-c3591.up.railway.app/api/$1"
    },
    {
      "src": "/v2/(.*)",
      "dest": "https://web-production-c3591.up.railway.app/v2/$1"
    },
    {
      "src": "/mines4/(.*)",
      "dest": "https://web-production-c3591.up.railway.app/mines4/$1"
    },
    {
      "src": "/emission-iq/(.*)",
      "dest": "https://web-production-c3591.up.railway.app/emission-iq/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
